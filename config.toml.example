# pincer configuration
#
# Copy this to ~/.openclaw/pincer.toml and edit. The keeper meta-runner reads
# from ~/.openclaw/pincer.toml by default; override with $PINCER_CONFIG.

owner = "alfredjbclaw"

[models]
# Mission tier — frontier model, called daily, plans the work.
mission = "anthropic/claude-opus-4-7"

# Goal tier — mid-tier, called hourly, classifies the live queue against the plan.
goal = "anthropic/claude-sonnet-4-6"

# Control tier — mid-tier, called every 5m, maintains ledger and dispatches workers.
control = "anthropic/claude-sonnet-4-6"

# Agent tier — the worker LLM running inside Codex / Claude Code.
# Provider routing is decided by [runtime].
agent = "openai/gpt-5.5"

# Tool tier — cheapest model, used by individual gh/git/test invocations.
tool = "anthropic/claude-haiku-4-5"

[runtime]
# Worker runtime. Codex is primary by default; fallback is the workspace-local
# Claude Code wrapper (tools/claude-code-wrapper.py).
primary = "codex"
fallback = "claude-code"

# Automatic fallback triggers. Any one fires the fallback for the current task only.
fallback_on = [
  "credit_exhausted",
  "auth_expired",
  "rate_limit_429",
  "three_strikes_failure",
]

[sandbox]
# Crabbox sandbox provider. Apple VZ runs locally on Apple Silicon (no cloud
# credentials, no monthly-spend exposure). See `crabbox doctor --provider <name>`
# to inspect alternatives (hetzner, aws, gcp, e2b, daytona, modal, etc.).
provider = "applevz"

# Sandbox gate posture. "every" runs every worker output through Crabbox before
# the orchestrator opens a PR. "tagged-needs-isolation" only sandboxes items
# the triage skill flagged. Default and recommended: "every".
gate = "every"

# Default test command. Each repo can override via .pincer.toml at its root.
default_test = "make test"

# Maximum concurrent Crabbox VMs at any one time. Each Apple VZ VM
# pre-allocates 8 GiB of host memory by default. Stacking VMs is the fastest
# way to burn through RAM on a workstation. Default: 1 (strict serialization).
# Raise only if the host has enough memory to absorb N × 8 GiB without paging.
max_concurrent = 1

# Per-lease idle timeout. Crabbox releases stale leases automatically; this is
# the safety net in case the orchestrator crashes mid-run. Match to your
# worker's expected ceiling. Default: 30 minutes.
idle_timeout = "30m"

[selection]
# Candidate selection + execution-feedback tuning. The defaults below reproduce
# Pincer's original cheap maintainer loop EXACTLY (one candidate per issue, one
# revise pass, no reproduction tests). Turn these up for benchmark-grade quality
# (e.g. SWE-bench), where the research shows selection — not generation — is the
# ceiling: coverage runs ~70-80% but realized score ~57-66%, and the gap is
# which candidate gets picked.

# Candidate coders fanned out PER ISSUE. >1 produces N independent fixes for the
# same bug; the selection cascade (regression rank -> reproduction-test flip ->
# AST-normalized majority vote -> Opus reviewer tie-break) picks the winner.
# Cost scales ~linearly with samples. Default: 1 (no fan-out, cascade no-ops).
samples = 1

# Bounded execution-feedback loop depth. Each round feeds the worker
# critic-interpreted feedback (Opus reads the failing test, not raw stderr) and
# re-verifies. The literature uses 5-8. Default: 1 (original single-shot revise).
max_revise_iters = 1

# Generate a fail-to-pass reproduction test per issue, validate it actually
# fails on the unpatched base, then prefer candidates that flip it. Highest-ROI
# verifier in the literature (~2x selection precision) but heavy: one extra
# sandbox VM run per candidate, serialized. Default: off.
repro_tests = false

# When revising, prepend an Opus root-cause reading of the failure to the
# worker feedback. Default: on (cheap, only fires during a revise).
interpret_failures = true

# Model used to author reproduction tests + interpret failures.
repro_model = "anthropic/claude-opus-4-8"

[cadence]
mission = "daily"
goal    = "hourly"
control = "5m"

[paths]
# Persistent state. Override only if you need to keep state under a different root.
log    = "~/.openclaw/pincer/log.md"
plans  = "~/.openclaw/pincer/plans/"
state  = "~/.openclaw/pincer/state.json"

# --- Repository allowlist -----------------------------------------------------
#
# One [[repos]] block per repository under pincer management.
# allowDelegate=false means the orchestrator only audits + triages; no worker
# dispatch. allowMerge=false means PRs go to the owner for the final click.
# allowRelease=true authorizes the orchestrator to draft + publish releases
# when the effective queue is empty and CI is green.

[[repos]]
name           = "alfredjbclaw/pincer-testbed"
allowDelegate  = true
allowMerge     = false
allowRelease   = false
test_command   = "make test"
